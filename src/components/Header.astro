---
import type { IHeaderProps } from "../types";
const {links} = Astro.props as IHeaderProps;
---

<header>
  <nav>
    <ul>
      {
        links.map((link) => (
          <li>
            <a href={link.href} target={link.target}>
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
    <!-- <ul>
        <li><a href="#">Icon</a></li>
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="#">Resources</a></li>
        </ul> -->
  </nav>
</header>

<style>
    header {
      display: flex;
      align-items: center;
      background-color: rgb(240, 218, 54);
      font-family: ui-monospace, "Cascadia Code", Consolas, monospace;
      height: 75px;
    }

    @media (max-width: 480px) {
      li {
        margin: 0 8px;
      }
    }

    ul {
        display: flex-start;
        align-items: center;
        justify-content: center;
    }

    li {
      display: inline-flex;
      list-style: none;
      margin: 0 16px;
    }

    li > a {
      color: #666;
    }
</style>
