---
// const links = Astro.props;
const dummyLinks = [
  {
    name: "Home",
    href: "/",
  },
  {
    name: "Blog",
    href: "/blog",
    target: "_blank",
  },
  {
    name: "Resources",
    href: "#",
  },
];
---

<header>
  <div>
    <ul>
      {
        dummyLinks.map((link) => (
          <li>
            <a href={link.href} target={link.target}>
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
    <!-- <ul>
            <li><a href="#">Icon</a></li>
            <li><a href="/">Home</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="#">Resources</a></li>
        </ul> -->
  </div>
</header>
