---
import type { ISidebarProps } from "../types";


const { links } = Astro.props as ISidebarProps;

const currentPath = Astro.url.pathname;
---

<aside class="sidebar" aria-label="Sidebar">
  <ul>
    {links.map((link) => (
      <li class={currentPath === link.href ? "active" : ""}>
        <a href={link.href} target={link.target}>
          {link.name}
        </a>
      </li>
    ))}
  </ul>
</aside>

<style>
  .sidebar {
    padding: 1rem;
    background: #f3f4f6;
    border-right: 1px solid #e5e7eb;
    font-family: ui-monospace, "Cascadia Code", Consolas, monospace;
    width: 100%;
  }

  @media (min-width: 768px) {
    .sidebar {
      width: 16rem;
      min-height: 100%;
    }
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  li {
    border-radius: 0.25rem;
  }

  li:hover {
    background: #e5e7eb;
  }

  li.active { 
    background: #d1d5db;
    font-weight: 500;
  }

  li > a {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    color: #374151;
  }
</style>